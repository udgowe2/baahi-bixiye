# Gemini API Key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=hier-deinen-key-eintragen

# Datenbank (im Docker-Setup legt docker-compose diese Werte fest)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=baahi
DB_PASSWORD=hier-ein-sicheres-passwort
DB_NAME=Baahi

# Nur fürs Docker-Compose-Setup: Root-Passwort der MariaDB
DB_ROOT_PASSWORD=hier-ein-anderes-sicheres-passwort

# Optional
PORT=3001
# UPLOAD_DIR=/data/uploads
